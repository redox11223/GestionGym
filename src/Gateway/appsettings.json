{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "autenticacion-route": {
        "ClusterId": "autenticacion-cluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ] 
      },
      "gestion-clientes-route": {
        "ClusterId": "gestion-clientes-cluster",
        "Match": { "Path": "/gestion/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/gestion" } ]
      },
      "entrenamiento-route": {
        "ClusterId": "entrenamiento-cluster",
        "Match": { "Path": "/entrenamiento/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/entrenamiento" } ]
      }
    },
    "Clusters": {
      "autenticacion-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5069" }
        }
      },
      "gestion-clientes-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5071" }
        }
      },
      "entrenamiento-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5141" }
        }
      }
    }
  }  
}
